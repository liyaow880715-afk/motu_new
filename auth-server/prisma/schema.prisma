generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum KeyType {
  PER_USE
  DAILY
  MONTHLY
}

enum KeyPlatform {
  DESKTOP_ONLY
  WEB_ONLY
  BOTH
}

model AccessKey {
  id          String      @id @default(cuid())
  key         String      @unique
  label       String?
  type        KeyType
  platform    KeyPlatform @default(BOTH)
  usedCount   Int         @default(0)
  activatedAt DateTime?
  expiresAt   DateTime?
  machineId   String?
  createdAt   DateTime    @default(now())
}
